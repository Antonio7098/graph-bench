{
  "evidence_spec_id": "evidence.prepare-edit.turn-trace-replay",
  "schema_version": 1,
  "required_facts": [
    {
      "fact_id": "turn-trace-has-request-response-selection-telemetry",
      "description": "Turn traces must preserve request, response, selection, and telemetry information.",
      "acceptable_proofs": [
        { "kind": "path", "value": "schemas/turn-trace.schema.json" },
        { "kind": "excerpt", "value": "\"selection\"" }
      ]
    },
    {
      "fact_id": "turn-trace-replay-is-hard-validated",
      "description": "Turn traces are validated before replay and reject invalid model payloads.",
      "acceptable_proofs": [
        { "kind": "symbol", "value": "graphbench_core::artifacts::TurnTrace::validate_for_replay" },
        { "kind": "excerpt", "value": "turn response must be validated before use" }
      ]
    }
  ],
  "supporting_facts": [
    {
      "fact_id": "rendered-sections-are-part-of-turn-selection",
      "description": "Rendered context sections are carried as part of prompt-visible selection output.",
      "acceptable_proofs": [
        { "kind": "path", "value": "schemas/context-window-section.schema.json" }
      ]
    }
  ],
  "distractor_facts": [
    {
      "fact_id": "score-report-controls-replay",
      "description": "Score reports are separate from replay validation.",
      "acceptable_proofs": [
        { "kind": "path", "value": "schemas/score-report.schema.json" }
      ]
    }
  ],
  "verification_targets": [
    { "kind": "command", "value": "cargo test turn_trace_validation_rejects_unvalidated_responses" }
  ]
}
