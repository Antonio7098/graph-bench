{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graphbench://schemas/evidence-spec.schema.json",
  "title": "Evidence Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_spec_id",
    "schema_version",
    "required_facts",
    "supporting_facts",
    "distractor_facts",
    "verification_targets"
  ],
  "properties": {
    "evidence_spec_id": { "type": "string" },
    "schema_version": { "const": 1 },
    "required_facts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fact" }
    },
    "supporting_facts": {
      "type": "array",
      "items": { "$ref": "#/$defs/fact" }
    },
    "distractor_facts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fact" }
    },
    "verification_targets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/verification_target" }
    }
  },
  "$defs": {
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fact_id", "description", "acceptable_proofs"],
      "properties": {
        "fact_id": { "type": "string" },
        "description": { "type": "string" },
        "acceptable_proofs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/proof" }
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "enum": ["path", "symbol", "logical_key", "excerpt", "graph_path", "coderef"] },
        "value": { "type": "string" }
      }
    },
    "verification_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string" },
        "value": { "type": "string" }
      }
    }
  }
}
